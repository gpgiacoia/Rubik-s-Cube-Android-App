<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ScanCubeActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.06" />

    <!-- Back Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/back"
        android:layout_width="100dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:elevation="6dp"
        android:text="Back"
        android:textColor="#FFFFFFFF"
        android:textSize="17sp"
        app:backgroundTint="#D32F2F"
        app:cornerRadius="16dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="#80FFFFFF"
        app:strokeColor="#BDBDBD"
        app:strokeWidth="1dp" />

    <!-- Shuffle Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/shuffle"
        android:layout_width="100dp"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="6dp"
        android:text="Shuffle"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        app:backgroundTint="#D32F2F"
        app:cornerRadius="16dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="#80FFFFFF"
        app:strokeColor="#BDBDBD"
        app:strokeWidth="1dp" />

    <!-- Lock Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/lock"
        android:layout_width="100dp"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:elevation="6dp"
        android:text="Lock"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        app:backgroundTint="#7C4C00FF"
        app:cornerRadius="16dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shuffle"
        app:rippleColor="#80FFFFFF"
        app:strokeColor="#BDBDBD"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="92dp"
        android:text="Rubik's Cube #1"
        android:textColor="#000000"
        android:textSize="30sp"
        android:textStyle="bold"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guideline_top" />

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Disconnected"
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cubeContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintWidth_percent="0.7">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanCube"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text="Scan Cube"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            app:backgroundTint="#D32F2F"
            app:cornerRadius="20dp"
            app:fontFamily="@font/irish_grover"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.example.rubikscubeapp.gl.CubeGLSurfaceView
            android:id="@+id/cubeSurface"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginTop="16dp"
        android:enabled="false"
        android:text="Start"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        app:backgroundTint="#BDBDBD"
        app:cornerRadius="20dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cubeContainer"
        app:layout_constraintWidth_percent="0.8" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginTop="24dp"
        android:enabled="false"
        android:text="Stop"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        app:backgroundTint="#BDBDBD"
        app:cornerRadius="20dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnStart"
        app:layout_constraintWidth_percent="0.8" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSpeed"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginTop="16dp"
        android:enabled="false"
        android:text="1x"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        app:backgroundTint="#BDBDBD"
        app:cornerRadius="20dp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnStop"
        app:layout_constraintWidth_percent="0.8" />

    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="0.000"
        android:textColor="#000000"
        android:textSize="22sp"
        app:fontFamily="@font/irish_grover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnSpeed" />

</androidx.constraintlayout.widget.ConstraintLayout>
